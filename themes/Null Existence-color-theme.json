{
	"name": "Null Existence",
	"colors": {
		"editor.background": "#000000",
		"editor.foreground": "#d0d0d0",
		"activityBar.background": "#000000",
		"activityBar.foreground": "#ffffff",
		"activityBar.inactiveForeground": "#404040",
		"activityBar.border": "#1a1a1a",
		"activityBarBadge.background": "#ffffff",
		"activityBarBadge.foreground": "#000000",
		"sideBarTitle.foreground": "#ffffff",
		"sideBar.background": "#000000",
		"sideBar.foreground": "#808080",
		"sideBar.border": "#1a1a1a",
		"statusBar.background": "#000000",
		"statusBar.foreground": "#d0d0d0",
		"statusBar.border": "#1a1a1a",
		"titleBar.activeBackground": "#000000",
		"titleBar.activeForeground": "#ffffff",
		"titleBar.border": "#1a1a1a",
		"tab.activeBackground": "#000000",
		"tab.activeForeground": "#ffffff",
		"tab.inactiveBackground": "#000000",
		"tab.inactiveForeground": "#404040",
		"tab.activeBorder": "#ffffff",
		"editor.selectionBackground": "#ffffff20",
		"editor.lineHighlightBackground": "#ffffff08",
		"terminal.background": "#000000",
		"terminal.foreground": "#d0d0d0"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#505050"
			}
		},
		{
			"name": "Keyword, Storage",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier",
				"keyword.control"
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Function",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"variable.function",
				"support.function"
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"name": "String",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#808080"
			}
		},
		{
			"name": "Number, Constant",
			"scope": [
				"constant.numeric",
				"constant.language",
				"support.constant"
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable"
			],
			"settings": {
				"foreground": "#d0d0d0"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Attributes",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#b0b0b0"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"meta.brace",
				"punctuation.definition.parameters"
			],
			"settings": {
				"foreground": "#606060"
			}
		}
	]
}